# AgentWeaver two-tier environment configuration
#
# Priority order (highest to lowest):
#   1. OS/shell environment variables (always win)
#   2. Project-local config: <project>/.agentweaver/.env
#   3. Global user config: ~/.agentweaver/.env
#
# Place shared settings (API keys, common defaults) in ~/.agentweaver/.env
# and project-specific overrides in <project>/.agentweaver/.env.
# The ~/.agentweaver directory is created automatically on first run.
#
# AGENTWEAVER_HOME is unrelated to the global config directory above —
# it controls the package installation directory only.

# AgentWeaver CLI
JIRA_API_KEY=your-jira-api-token
JIRA_BASE_URL=https://jira.example.com
AGENTWEAVER_HOME=/absolute/path/to/AgentWeaver

# Optional overrides for local binaries and models
CODEX_BIN=codex
CLAUDE_BIN=claude
CODEX_MODEL=gpt-5.4
CLAUDE_REVIEW_MODEL=opus
CLAUDE_SUMMARY_MODEL=haiku

# Private Go modules and git transport policy
GOPRIVATE=gitlab.yourdomain.org/*
GONOSUMDB=gitlab.yourdomain.org/*
GONOPROXY=gitlab.yourdomain.org/*
GIT_ALLOW_PROTOCOL=file:https:ssh

# Non-interactive codex-exec defaults
CODEX_PROMPT=
CODEX_EXEC_FLAGS=--dangerously-bypass-approvals-and-sandbox

TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_CHAT_ID=change-me
