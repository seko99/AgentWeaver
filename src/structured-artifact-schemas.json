    "type": "object",
    "properties": {
      "artifact_id": { "type": "string", "nonEmpty": true },
      "logical_key": { "type": "string", "nonEmpty": true, "pattern": "^[a-z0-9][a-z0-9._/-]*$" },
      "scope": { "type": "string", "nonEmpty": true },
      "run_id": { "type": "string", "nonEmpty": true },
      "flow_id": { "type": "string", "nonEmpty": true },
