{
  "bug-analysis/v1": {
    "type": "object",
    "properties": {
      "summary": { "type": "string", "nonEmpty": true },
      "suspected_root_cause": {
        "type": "object",
        "properties": {
          "hypothesis": { "type": "string", "nonEmpty": true },
          "confidence": { "type": "string", "nonEmpty": true }
        },
        "required": ["hypothesis", "confidence"]
      },
      "reproduction_steps": {
        "type": "array",
        "items": { "type": "string", "nonEmpty": true },
        "minItems": 1
      },
      "affected_components": {
        "type": "array",
        "items": { "type": "string", "nonEmpty": true },
        "minItems": 1
      },
      "evidence": {
        "type": "array",
        "items": { "type": "string", "nonEmpty": true },
        "minItems": 1
      },
      "risks": {
        "type": "array",
        "items": { "type": "string", "nonEmpty": true }
      },
      "open_questions": {
        "type": "array",
        "items": { "type": "string", "nonEmpty": true }
      }
    },
    "required": [
      "summary",
      "suspected_root_cause",
      "reproduction_steps",
      "affected_components",
      "evidence",
      "risks",
      "open_questions"
    ]
  },
