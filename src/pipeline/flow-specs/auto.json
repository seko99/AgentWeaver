{
  "kind": "auto-flow",
  "version": 1,
  "constants": {
    "autoReviewFixExtraPrompt": "Исправлять только блокеры, критикалы и важные"
  },
  "phases": [
    {
      "id": "plan",
      "steps": [
        {
          "id": "fetch_jira",
          "node": "jira-fetch",
          "params": {
            "jiraApiUrl": { "ref": "params.jiraApiUrl" },
            "outputFile": {
              "artifact": {
                "kind": "jira-task-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            },
            "attachmentsManifestFile": {
              "artifact": {
                "kind": "jira-attachments-manifest-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            },
            "attachmentsContextFile": {
              "artifact": {
                "kind": "jira-attachments-context-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-file",
              "path": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "message": "Jira fetch node did not produce the Jira task file."
            },
            {
              "kind": "require-file",
              "path": {
                "artifact": {
                  "kind": "jira-attachments-manifest-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "message": "Jira fetch node did not produce the Jira attachments manifest file."
            },
            {
              "kind": "require-file",
              "path": {
                "artifact": {
                  "kind": "jira-attachments-context-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "message": "Jira fetch node did not produce the Jira attachments context file."
            }
          ]
        },
        {
          "id": "load_existing_task_summary",
          "when": {
            "all": [
              { "not": { "ref": "params.forceRefresh" } },
              {
                "exists": {
                  "artifact": {
                    "kind": "task-summary-file",
                    "taskKey": { "ref": "params.taskKey" }
                  }
                }
              }
            ]
          },
          "node": "summary-file-load",
          "params": {
            "path": {
              "artifact": {
                "kind": "task-summary-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          }
        },
        {
          "id": "generate_task_summary",
          "when": {
            "any": [
              { "ref": "params.forceRefresh" },
              {
                "not": {
                  "exists": {
                    "artifact": {
                      "kind": "task-summary-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  }
                }
              }
            ]
          },
          "node": "llm-prompt",
          "prompt": {
            "templateRef": "task-summary",
            "vars": {
              "jira_task_file": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "task_summary_file": {
                "artifact": {
                  "kind": "task-summary-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "task_summary_json_file": {
                "artifact": {
                  "kind": "task-summary-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              }
            },
            "format": "plain"
          },
          "params": {
            "labelText": { "const": "Preparing task summary" },
            "outputFile": {
              "artifact": {
                "kind": "task-summary-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            },
            "requiredArtifacts": {
              "list": [
                {
                  "artifact": {
                    "kind": "task-summary-json-file",
                    "taskKey": { "ref": "params.taskKey" }
                  }
                }
              ]
            },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" }
          },
          "expect": [
            {
              "kind": "require-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "paths": {
                "list": [
                  {
                    "artifact": {
                      "kind": "task-summary-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  }
                ]
              },
              "message": "Summary did not produce the task summary artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "task-summary-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "task-summary/v1"
                }
              ],
              "message": "Summary produced invalid structured artifacts."
            }
          ],
          "after": [
            {
              "kind": "set-summary-from-file",
              "when": { "not": { "ref": "context.dryRun" } },
              "path": {
                "artifact": {
                  "kind": "task-summary-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              }
            }
          ]
        },
        {
          "id": "generate_planning_questions",
          "node": "llm-prompt",
          "prompt": {
            "templateRef": "plan-questions",
            "vars": {
              "jira_task_file": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_attachments_manifest_file": {
                "artifact": {
                  "kind": "jira-attachments-manifest-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_attachments_context_file": {
                "artifact": {
                  "kind": "jira-attachments-context-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "planning_questions_json_file": {
                "artifact": {
                  "kind": "planning-questions-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Generating planning questions" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" },
            "requiredArtifacts": {
              "list": [
                {
                  "artifact": {
                    "kind": "planning-questions-json-file",
                    "taskKey": { "ref": "params.taskKey" }
                  }
                }
              ]
            }
          },
          "expect": [
            {
              "kind": "require-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "paths": {
                "list": [
                  {
                    "artifact": {
                      "kind": "planning-questions-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  }
                ]
              },
              "message": "Planning questions step did not produce the questions artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "planning-questions-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "planning-questions/v1"
                }
              ],
              "message": "Planning questions step produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "build_planning_questions_form",
          "node": "planning-questions-form",
          "params": {
            "planningQuestionsJsonFile": {
              "artifact": {
                "kind": "planning-questions-json-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            },
            "formId": { "const": "planning-questions" },
            "title": { "const": "Planning Questions" },
            "description": {
              "const": "Ответьте на вопросы модели, если они нужны для точного design/plan. Если вопросов нет, шаг завершится автоматически."
            }
          }
        },
        {
          "id": "collect_planning_answers",
          "node": "user-input",
          "params": {
            "formId": { "ref": "steps.plan.build_planning_questions_form.value.formId" },
            "title": { "ref": "steps.plan.build_planning_questions_form.value.title" },
            "description": { "ref": "steps.plan.build_planning_questions_form.value.description" },
            "submitLabel": { "const": "Continue planning" },
            "fields": { "ref": "steps.plan.build_planning_questions_form.value.fields" },
            "outputFile": {
              "artifact": {
                "kind": "planning-answers-json-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-structured-artifacts",
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "planning-answers-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "user-input/v1"
                }
              ],
              "message": "Planning answers input is missing or invalid."
            }
          ]
        },
        {
          "id": "run_plan",
          "node": "llm-prompt",
          "prompt": {
            "templateRef": "plan",
            "vars": {
              "jira_task_file": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_attachments_manifest_file": {
                "artifact": {
                  "kind": "jira-attachments-manifest-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_attachments_context_file": {
                "artifact": {
                  "kind": "jira-attachments-context-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "design_file": {
                "artifact": {
                  "kind": "design-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "design_json_file": {
                "artifact": {
                  "kind": "design-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "plan_file": {
                "artifact": {
                  "kind": "plan-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "plan_json_file": {
                "artifact": {
                  "kind": "plan-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "qa_file": {
                "artifact": {
                  "kind": "qa-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "qa_json_file": {
                "artifact": {
                  "kind": "qa-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              }
            },
            "extraPrompt": {
              "appendPrompt": {
                "base": { "ref": "params.extraPrompt" },
                "suffix": { "ref": "steps.plan.collect_planning_answers.value.promptSuffix" }
              }
            },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running planning mode" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" }
          },
          "expect": [
            {
              "kind": "require-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "paths": {
                "artifactList": {
                  "kind": "plan-artifacts",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "message": "Plan mode did not produce the required artifacts."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "design-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "implementation-design/v1"
                },
                {
                  "path": {
                    "artifact": {
                      "kind": "plan-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "implementation-plan/v1"
                },
                {
                  "path": {
                    "artifact": {
                      "kind": "qa-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "qa-plan/v1"
                }
              ],
              "message": "Plan mode produced invalid structured artifacts."
            }
          ]
        }
      ]
    },
    {
      "id": "implement",
      "steps": [
        {
          "id": "run_implement",
          "node": "llm-prompt",
          "prompt": {
            "templateRef": "implement",
            "vars": {
              "design_file": {
                "artifact": {
                  "kind": "design-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "design_json_file": {
                "artifact": {
                  "kind": "design-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "plan_file": {
                "artifact": {
                  "kind": "plan-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "plan_json_file": {
                "artifact": {
                  "kind": "plan-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running implementation mode locally" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" }
          }
        }
      ]
    },
    {
      "id": "run_go_linter_loop_after_implement",
      "steps": [
        {
          "id": "run_go_linter_loop",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "run-go-linter-loop.json" },
            "labelText": { "const": "Running run-go-linter-loop after implement" },
            "taskKey": { "ref": "params.taskKey" },
            "runGoLinterScript": { "ref": "params.runGoLinterScript" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" }
          }
        }
      ]
    },
    {
      "id": "run_go_tests_loop_after_implement",
      "steps": [
        {
          "id": "run_go_tests_loop",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "run-go-tests-loop.json" },
            "labelText": { "const": "Running run-go-tests-loop after implement" },
            "taskKey": { "ref": "params.taskKey" },
            "runGoTestsScript": { "ref": "params.runGoTestsScript" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" }
          }
        }
      ]
    },
    {
      "id": "review",
      "when": {
        "not": {
          "exists": {
            "artifact": {
              "kind": "ready-to-merge-file",
              "taskKey": { "ref": "params.taskKey" }
            }
          }
        }
      },
      "steps": [
        {
          "id": "run_review",
          "node": "llm-prompt",
          "prompt": {
            "templateRef": "review",
            "vars": {
              "jira_task_file": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "design_file": {
                "artifact": {
                  "kind": "design-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "design_json_file": {
                "artifact": {
                  "kind": "design-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "plan_file": {
                "artifact": {
                  "kind": "plan-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "plan_json_file": {
                "artifact": {
                  "kind": "plan-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "review_file": {
                "artifact": {
                  "kind": "review-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              },
              "review_json_file": {
                "artifact": {
                  "kind": "review-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running review mode" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" }
          },
          "expect": [
            {
              "kind": "require-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "paths": {
                "list": [
                  {
                    "artifact": {
                      "kind": "review-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "const": 1 }
                    }
                  }
                ]
              },
              "message": "Review did not produce the required review artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "review-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "const": 1 }
                    }
                  },
                  "schemaId": "review-findings/v1"
                }
              ],
              "message": "Review produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "summarize_review",
          "when": { "not": { "ref": "context.dryRun" } },
          "node": "llm-prompt",
          "prompt": {
            "templateRef": "review-summary",
            "vars": {
              "review_file": {
                "artifact": {
                  "kind": "review-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              },
              "review_summary_file": {
                "artifact": {
                  "kind": "review-summary-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              }
            },
            "format": "plain"
          },
          "params": {
            "labelText": { "const": "Preparing review summary" },
            "outputFile": {
              "artifact": {
                "kind": "review-summary-file",
                "taskKey": { "ref": "params.taskKey" },
                "iteration": { "const": 1 }
              }
            },
            "summaryTitle": { "const": "Review Comments" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" }
          }
        },
        {
          "id": "run_review_reply",
          "node": "llm-prompt",
          "prompt": {
            "templateRef": "review-reply",
            "vars": {
              "review_file": {
                "artifact": {
                  "kind": "review-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              },
              "review_json_file": {
                "artifact": {
                  "kind": "review-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              },
              "jira_task_file": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "design_file": {
                "artifact": {
                  "kind": "design-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "design_json_file": {
                "artifact": {
                  "kind": "design-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "plan_file": {
                "artifact": {
                  "kind": "plan-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "plan_json_file": {
                "artifact": {
                  "kind": "plan-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "review_reply_file": {
                "artifact": {
                  "kind": "review-reply-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              },
              "review_reply_json_file": {
                "artifact": {
                  "kind": "review-reply-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running review reply mode" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" }
          },
          "expect": [
            {
              "kind": "require-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "paths": {
                "list": [
                  {
                    "artifact": {
                      "kind": "review-reply-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "const": 1 }
                    }
                  }
                ]
              },
              "message": "Review reply did not produce the required review-reply artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "review-reply-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "const": 1 }
                    }
                  },
                  "schemaId": "review-reply/v1"
                }
              ],
              "message": "Review reply produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "summarize_review_reply",
          "when": { "not": { "ref": "context.dryRun" } },
          "node": "llm-prompt",
          "prompt": {
            "templateRef": "review-reply-summary",
            "vars": {
              "review_reply_file": {
                "artifact": {
                  "kind": "review-reply-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              },
              "review_reply_summary_file": {
                "artifact": {
                  "kind": "review-reply-summary-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              }
            },
            "format": "plain"
          },
          "params": {
            "labelText": { "const": "Preparing reply summary" },
            "outputFile": {
              "artifact": {
                "kind": "review-reply-summary-file",
                "taskKey": { "ref": "params.taskKey" },
                "iteration": { "const": 1 }
              }
            },
            "summaryTitle": { "const": "Reply Summary" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" }
          }
        },
        {
          "id": "check_ready_to_merge",
          "node": "file-check",
          "stopFlowIf": {
            "ref": "steps.review.check_ready_to_merge.outputs.exists"
          },
          "params": {
            "path": {
              "artifact": {
                "kind": "ready-to-merge-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            },
            "panelTitle": { "const": "Ready To Merge" },
            "foundMessage": { "const": "Изменения готовы к merge\nФайл ready-to-merge.md создан." },
            "tone": { "const": "green" }
          }
        }
      ]
    },
    {
      "id": "review_fix",
      "when": {
        "not": {
          "ref": "steps.review.check_ready_to_merge.outputs.exists"
        }
      },
      "steps": [
        {
          "id": "run_review_fix",
          "node": "llm-prompt",
          "prompt": {
            "templateRef": "review-fix",
            "vars": {
              "review_reply_file": {
                "artifact": {
                  "kind": "review-reply-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              },
              "review_reply_json_file": {
                "artifact": {
                  "kind": "review-reply-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              },
              "items": { "ref": "params.reviewFixPoints" },
              "review_fix_file": {
                "artifact": {
                  "kind": "review-fix-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              },
              "review_fix_json_file": {
                "artifact": {
                  "kind": "review-fix-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "const": 1 }
                }
              }
            },
            "extraPrompt": {
              "appendPrompt": {
                "base": { "ref": "params.extraPrompt" },
                "suffix": { "ref": "flow.autoReviewFixExtraPrompt" }
              }
            },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running review-fix mode locally" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" }
          },
          "expect": [
            {
              "kind": "require-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "paths": {
                "list": [
                  {
                    "artifact": {
                      "kind": "review-fix-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "const": 1 }
                    }
                  }
                ]
              },
              "message": "Review-fix mode did not produce the required review-fix artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "review-fix-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "const": 1 }
                    }
                  },
                  "schemaId": "review-fix-report/v1"
                }
              ],
              "message": "Review-fix mode produced invalid structured artifacts."
            }
          ]
        }
      ]
    },
    {
      "id": "run_go_linter_loop_after_review_fix",
      "when": {
        "not": {
          "ref": "steps.review.check_ready_to_merge.outputs.exists"
        }
      },
      "steps": [
        {
          "id": "run_go_linter_loop",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "run-go-linter-loop.json" },
            "labelText": { "const": "Running run-go-linter-loop after review-fix" },
            "taskKey": { "ref": "params.taskKey" },
            "runGoLinterScript": { "ref": "params.runGoLinterScript" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" }
          }
        }
      ]
    },
    {
      "id": "run_go_tests_loop_after_review_fix",
      "when": {
        "not": {
          "ref": "steps.review.check_ready_to_merge.outputs.exists"
        }
      },
      "steps": [
        {
          "id": "run_go_tests_loop",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "run-go-tests-loop.json" },
            "labelText": { "const": "Running run-go-tests-loop after review-fix" },
            "taskKey": { "ref": "params.taskKey" },
            "runGoTestsScript": { "ref": "params.runGoTestsScript" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" }
          }
        }
      ]
    }
  ]
}
