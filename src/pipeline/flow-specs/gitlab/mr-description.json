{
  "kind": "mr-description-flow",
  "version": 1,
  "phases": [
    {
      "id": "mr_description",
      "steps": [
        {
          "id": "run_codex_mr_description",
          "node": "llm-prompt",
          "prompt": {
            "templateRef": "mr-description",
            "vars": {
              "jira_task_file": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "mr_description_file": {
                "artifact": {
                  "kind": "mr-description-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "mr_description_json_file": {
                "artifact": {
                  "kind": "mr-description-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running Codex MR description mode" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" },
            "requiredArtifacts": {
              "list": [
                {
                  "artifact": {
                    "kind": "mr-description-file",
                    "taskKey": { "ref": "params.taskKey" }
                  }
                },
                {
                  "artifact": {
                    "kind": "mr-description-json-file",
                    "taskKey": { "ref": "params.taskKey" }
                  }
                }
              ]
            }
          },
          "expect": [
            {
              "kind": "require-file",
              "when": { "not": { "ref": "context.dryRun" } },
              "path": {
                "artifact": {
                  "kind": "mr-description-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "message": "MR description mode did not produce the MR description artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "mr-description-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "mr-description/v1"
                }
              ],
              "message": "MR description mode produced invalid structured artifacts."
            }
          ]
        }
      ]
    }
  ]
}
