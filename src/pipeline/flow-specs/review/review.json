{
  "kind": "review-flow",
  "version": 1,
  "description": "Performs code review of current changes against the task design and plan. Produces structured review findings with severity levels and a ready-to-merge verdict.",
  "phases": [
    {
      "id": "review",
      "steps": [
        {
          "id": "run_review",
          "node": "llm-prompt",
          "routingGroup": "review",
          "prompt": {
            "templateRef": "review",
            "vars": {
              "jira_task_file": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "design_file": {
                "artifact": {
                  "kind": "design-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "design_json_file": {
                "artifact": {
                  "kind": "design-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "plan_file": {
                "artifact": {
                  "kind": "plan-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "plan_json_file": {
                "artifact": {
                  "kind": "plan-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "review_file": {
                "artifact": {
                  "kind": "review-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              },
              "review_json_file": {
                "artifact": {
                  "kind": "review-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": {
              "template": "Running review mode (iteration {iteration})",
              "vars": {
                "iteration": { "ref": "params.iteration" }
              }
            },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" }
          },
          "expect": [
            {
              "kind": "require-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "paths": {
                "list": [
                  {
                    "artifact": {
                      "kind": "review-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.iteration" }
                    }
                  }
                ]
              },
              "message": "Review did not produce the required review artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "review-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.iteration" }
                    }
                  },
                  "schemaId": "review-findings/v1"
                }
              ],
              "message": "Review produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "check_ready_to_merge",
          "node": "file-check",
          "params": {
            "path": {
              "artifact": {
                "kind": "ready-to-merge-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            },
            "panelTitle": { "const": "Ready To Merge" },
            "foundMessage": { "const": "Changes are ready to merge.\nFile ready-to-merge.md has been created." },
            "tone": { "const": "green" }
          }
        }
      ]
    }
  ]
}
