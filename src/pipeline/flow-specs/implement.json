{
  "kind": "implement-flow",
  "version": 1,
  "description": "Runs LLM-backed implementation based on previously approved design, plan, and QA artifacts. Executes code changes locally in the project working directory.",
  "phases": [
    {
      "id": "implement",
      "steps": [
        {
          "id": "run_implement",
          "node": "llm-prompt",
          "routingGroup": "implementation",
          "prompt": {
            "templateRef": "implement",
            "vars": {
              "design_file": {
                "artifact": {
                  "kind": "design-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.planningIteration" }
                }
              },
              "design_json_file": {
                "artifact": {
                  "kind": "design-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.planningIteration" }
                }
              },
              "plan_file": {
                "artifact": {
                  "kind": "plan-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.planningIteration" }
                }
              },
              "plan_json_file": {
                "artifact": {
                  "kind": "plan-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.planningIteration" }
                }
              },
              "qa_file": {
                "artifact": {
                  "kind": "qa-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.planningIteration" }
                }
              },
              "qa_json_file": {
                "artifact": {
                  "kind": "qa-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.planningIteration" }
                }
              },
              "project_guidance_file": { "ref": "params.projectGuidanceFile" },
              "project_guidance_json_file": { "ref": "params.projectGuidanceJsonFile" }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running implementation mode locally" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" }
          }
        }
      ]
    }
  ]
}
