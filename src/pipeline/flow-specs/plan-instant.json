{
  "kind": "plan-instant-flow",
  "version": 1,
  "description": "Collects immutable manual task input in the current project scope, generates clarifying questions, collects answers, and produces design, implementation plan, and QA plan as structured JSON and localized markdown artifacts without Jira fetch.",
  "phases": [
    {
      "id": "plan",
      "steps": [
        {
          "id": "collect_task_source",
          "when": {
            "not": {
              "exists": {
                "artifact": {
                  "kind": "instant-task-input-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              }
            }
          },
          "node": "user-input",
          "params": {
            "formId": { "const": "instant-task-input" },
            "title": { "const": "Instant Task Input" },
            "description": {
              "const": "Describe the task for this branch-derived lineage. The saved task input is immutable for the current scope and will be reused on reruns."
            },
            "submitLabel": { "const": "Start planning" },
            "fields": {
              "list": [
                {
                  "const": {
                    "id": "task_description",
                    "type": "text",
                    "label": "Task description",
                    "help": "Describe the requested work. This text becomes the source-of-truth input for the instant-task lineage.",
                    "required": true,
                    "multiline": true,
                    "rows": 5,
                    "placeholder": "e.g. add an instant-task command that runs planning, implementation, and review without Jira"
                  }
                },
                {
                  "const": {
                    "id": "additional_instructions",
                    "type": "text",
                    "label": "Additional instructions",
                    "help": "Optional extra constraints, references, or implementation notes for the same task lineage.",
                    "required": false,
                    "multiline": true,
                    "rows": 4,
                    "placeholder": "e.g. keep the existing Jira-backed flows unchanged, add tests for review routing"
                  }
                }
              ]
            },
            "outputFile": {
              "artifact": {
                "kind": "instant-task-input-json-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-structured-artifacts",
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "instant-task-input-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "user-input/v1"
                }
              ],
              "message": "Instant-task source input is missing or invalid."
            }
          ]
        },
        {
          "id": "validate_task_source_artifact",
          "when": {
            "exists": {
              "artifact": {
                "kind": "instant-task-input-json-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          },
          "node": "file-check",
          "params": {
            "path": {
              "artifact": {
                "kind": "instant-task-input-json-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            },
            "panelTitle": { "const": "Instant Task Source Artifact" },
            "foundMessage": {
              "const": "Validated the immutable instant-task source artifact before continuing planning."
            },
            "tone": { "const": "cyan" }
          },
          "expect": [
            {
              "kind": "require-structured-artifacts",
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "instant-task-input-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "user-input/v1"
                }
              ],
              "message": "Instant-task source input is missing or invalid."
            }
          ]
        },
        {
          "id": "generate_planning_questions",
          "node": "llm-prompt",
          "routingGroup": "planning",
          "prompt": {
            "templateRef": "plan-instant-questions",
            "vars": {
              "task_input_file": {
                "artifact": {
                  "kind": "instant-task-input-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "planning_questions_json_file": {
                "artifact": {
                  "kind": "planning-questions-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Generating planning questions" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" },
            "requiredArtifacts": {
              "list": [
                {
                  "artifact": {
                    "kind": "planning-questions-json-file",
                    "taskKey": { "ref": "params.taskKey" }
                  }
                }
              ]
            }
          },
          "expect": [
            {
              "kind": "require-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "paths": {
                "list": [
                  {
                    "artifact": {
                      "kind": "planning-questions-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  }
                ]
              },
              "message": "Planning questions step did not produce the questions artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "planning-questions-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "planning-questions/v1"
                }
              ],
              "message": "Planning questions step produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "build_planning_questions_form",
          "node": "planning-questions-form",
          "params": {
            "planningQuestionsJsonFile": {
              "artifact": {
                "kind": "planning-questions-json-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            },
            "formId": { "const": "planning-questions" },
            "title": { "const": "Planning Questions" },
            "description": {
              "const": "Answer the model's questions if they are needed for an accurate design/plan. If there are no questions, this step will complete automatically."
            }
          }
        },
        {
          "id": "notify_questions_need_answering",
          "when": {
            "not": {
              "equals": [
                { "ref": "steps.plan.build_planning_questions_form.value.questionCount" },
                { "const": 0 }
              ]
            }
          },
          "node": "telegram-notify",
          "params": {
            "message": { "const": "Questions need answering" }
          }
        },
        {
          "id": "collect_planning_answers",
          "node": "user-input",
          "params": {
            "formId": { "ref": "steps.plan.build_planning_questions_form.value.formId" },
            "title": { "ref": "steps.plan.build_planning_questions_form.value.title" },
            "description": { "ref": "steps.plan.build_planning_questions_form.value.description" },
            "submitLabel": { "const": "Continue planning" },
            "fields": { "ref": "steps.plan.build_planning_questions_form.value.fields" },
            "outputFile": {
              "artifact": {
                "kind": "planning-answers-json-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-structured-artifacts",
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "planning-answers-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "user-input/v1"
                }
              ],
              "message": "Planning answers input is missing or invalid."
            }
          ]
        },
        {
          "id": "run_plan",
          "node": "llm-prompt",
          "routingGroup": "planning",
          "prompt": {
            "templateRef": "plan-instant",
            "vars": {
              "task_input_file": {
                "artifact": {
                  "kind": "instant-task-input-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "planning_answers_json_file": {
                "artifact": {
                  "kind": "planning-answers-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "design_file": {
                "artifact": {
                  "kind": "design-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.designIteration" }
                }
              },
              "design_json_file": {
                "artifact": {
                  "kind": "design-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.designIteration" }
                }
              },
              "plan_file": {
                "artifact": {
                  "kind": "plan-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.planIteration" }
                }
              },
              "plan_json_file": {
                "artifact": {
                  "kind": "plan-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.planIteration" }
                }
              },
              "qa_file": {
                "artifact": {
                  "kind": "qa-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.qaIteration" }
                }
              },
              "qa_json_file": {
                "artifact": {
                  "kind": "qa-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.qaIteration" }
                }
              }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running planning mode" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" },
            "requiredArtifacts": {
              "list": [
                {
                  "artifact": {
                    "kind": "design-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.designIteration" }
                  }
                },
                {
                  "artifact": {
                    "kind": "design-json-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.designIteration" }
                  }
                },
                {
                  "artifact": {
                    "kind": "plan-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.planIteration" }
                  }
                },
                {
                  "artifact": {
                    "kind": "plan-json-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.planIteration" }
                  }
                },
                {
                  "artifact": {
                    "kind": "qa-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.qaIteration" }
                  }
                },
                {
                  "artifact": {
                    "kind": "qa-json-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.qaIteration" }
                  }
                }
              ]
            }
          },
          "expect": [
            {
              "kind": "require-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "paths": {
                "list": [
                  {
                    "artifact": {
                      "kind": "design-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.designIteration" }
                    }
                  },
                  {
                    "artifact": {
                      "kind": "design-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.designIteration" }
                    }
                  },
                  {
                    "artifact": {
                      "kind": "plan-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.planIteration" }
                    }
                  },
                  {
                    "artifact": {
                      "kind": "plan-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.planIteration" }
                    }
                  },
                  {
                    "artifact": {
                      "kind": "qa-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.qaIteration" }
                    }
                  },
                  {
                    "artifact": {
                      "kind": "qa-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.qaIteration" }
                    }
                  }
                ]
              },
              "message": "Plan mode did not produce the required artifacts."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "design-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.designIteration" }
                    }
                  },
                  "schemaId": "implementation-design/v1"
                },
                {
                  "path": {
                    "artifact": {
                      "kind": "plan-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.planIteration" }
                    }
                  },
                  "schemaId": "implementation-plan/v1"
                },
                {
                  "path": {
                    "artifact": {
                      "kind": "qa-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.qaIteration" }
                    }
                  },
                  "schemaId": "qa-plan/v1"
                }
              ],
              "message": "Plan mode produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "notify_plan_complete",
          "node": "telegram-notify",
          "params": {
            "message": { "const": "Plan phase complete" }
          }
        }
      ]
    }
  ]
}
