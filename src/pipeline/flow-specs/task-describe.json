{
  "kind": "task-describe-flow",
  "version": 1,
  "phases": [
    {
      "id": "task_describe",
      "steps": [
        {
          "id": "collect_task_source",
          "node": "user-input",
          "params": {
            "formId": { "const": "task-describe-source-input" },
            "title": { "const": "Task Describe Source" },
            "description": {
              "const": "Укажи либо Jira issue key / browse URL, либо кратко опиши задачу вручную."
            },
            "submitLabel": { "const": "Generate description" },
            "fields": {
              "list": [
                {
                  "const": {
                    "id": "jira_ref",
                    "type": "text",
                    "label": "Jira issue key or browse URL",
                    "help": "Например: DEMO-3288 или https://jira.example.ru/browse/DEMO-3288. Оставь пустым, если опишешь задачу вручную.",
                    "required": false
                  }
                },
                {
                  "const": {
                    "id": "task_description",
                    "type": "text",
                    "label": "Task description",
                    "help": "Кратко опиши задачу своими словами. Заполни это поле только если Jira нет.",
                    "required": false,
                    "multiline": true,
                    "rows": 3,
                    "placeholder": "Например: добавить фильтр по статусу в список заказов и сохранить выбранное значение в URL"
                  }
                }
              ]
            },
            "outputFile": {
              "artifact": {
                "kind": "task-describe-input-json-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-structured-artifacts",
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "task-describe-input-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "user-input/v1"
                }
              ],
              "message": "Task describe source input is missing or invalid."
            }
          ]
        },
        {
          "id": "resolve_jira_context",
          "node": "jira-context",
          "when": {
            "ref": "steps.task_describe.collect_task_source.value.values.jira_ref"
          },
          "params": {
            "jiraRef": {
              "ref": "steps.task_describe.collect_task_source.value.values.jira_ref"
            }
          }
        },
        {
          "id": "fetch_jira",
          "node": "jira-fetch",
          "when": {
            "ref": "steps.task_describe.collect_task_source.value.values.jira_ref"
          },
          "params": {
            "jiraApiUrl": { "ref": "steps.task_describe.resolve_jira_context.value.jiraApiUrl" },
            "outputFile": {
              "artifact": {
                "kind": "jira-task-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-file",
              "path": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "message": "Jira fetch node did not produce the Jira task file."
            }
          ]
        },
        {
          "id": "run_codex_task_describe_from_jira",
          "node": "llm-prompt",
          "when": {
            "ref": "steps.task_describe.collect_task_source.value.values.jira_ref"
          },
          "prompt": {
            "inlineTemplate": "Посмотри задачу в {jira_task_file}. Сформируй типичное описание задачи для Jira простым продуктовым языком, без перегруза техническими деталями. Структура описания: Проблема, Контекст, Что нужно сделать, Критерии готовности. Пиши только то, что помогает понять суть задачи и ожидаемый результат; технические детали, названия внутренних сервисов, моделей данных, файлов, REST-методов и шаги реализации упоминай только если без них теряется смысл задачи. Сначала запиши source-of-truth JSON в {jira_description_json_file} в виде объекта { summary: string }, затем markdown-версию в {jira_description_file}.",
            "vars": {
              "jira_task_file": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_description_file": {
                "artifact": {
                  "kind": "jira-description-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_description_json_file": {
                "artifact": {
                  "kind": "jira-description-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running Codex task description mode" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" },
            "requiredArtifacts": {
              "list": [
                {
                  "artifact": {
                    "kind": "jira-description-file",
                    "taskKey": { "ref": "params.taskKey" }
                  }
                },
                {
                  "artifact": {
                    "kind": "jira-description-json-file",
                    "taskKey": { "ref": "params.taskKey" }
                  }
                }
              ]
            }
          },
          "expect": [
            {
              "kind": "require-file",
              "when": { "not": { "ref": "context.dryRun" } },
              "path": {
                "artifact": {
                  "kind": "jira-description-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "message": "Task describe mode did not produce the Jira description artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "jira-description-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "jira-description/v1"
                }
              ],
              "message": "Task describe mode produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "run_codex_task_describe_from_input",
          "node": "llm-prompt",
          "when": {
            "not": {
              "ref": "steps.task_describe.collect_task_source.value.values.jira_ref"
            }
          },
          "prompt": {
            "inlineTemplate": "Посмотри пользовательское описание задачи в {task_input_file}. Используй поле values.task_description как source of truth. Сформируй типичное описание задачи для Jira простым продуктовым языком, без перегруза техническими деталями. Структура описания: Проблема, Контекст, Что нужно сделать, Критерии готовности. Если в пользовательском описании не хватает деталей, не выдумывай их и оставляй формулировки достаточно общими. Сначала запиши source-of-truth JSON в {jira_description_json_file} в виде объекта { summary: string }, затем markdown-версию в {jira_description_file}.",
            "vars": {
              "task_input_file": {
                "artifact": {
                  "kind": "task-describe-input-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_description_file": {
                "artifact": {
                  "kind": "jira-description-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_description_json_file": {
                "artifact": {
                  "kind": "jira-description-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              }
            },
            "extraPrompt": {
              "appendPrompt": {
                "base": { "ref": "params.extraPrompt" },
                "suffix": { "ref": "steps.task_describe.collect_task_source.value.promptSuffix" }
              }
            },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running Codex task description mode" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" },
            "requiredArtifacts": {
              "list": [
                {
                  "artifact": {
                    "kind": "jira-description-file",
                    "taskKey": { "ref": "params.taskKey" }
                  }
                },
                {
                  "artifact": {
                    "kind": "jira-description-json-file",
                    "taskKey": { "ref": "params.taskKey" }
                  }
                }
              ]
            }
          },
          "expect": [
            {
              "kind": "require-file",
              "when": { "not": { "ref": "context.dryRun" } },
              "path": {
                "artifact": {
                  "kind": "jira-description-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "message": "Task describe mode did not produce the Jira description artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "jira-description-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "jira-description/v1"
                }
              ],
              "message": "Task describe mode produced invalid structured artifacts."
            }
          ]
        }
      ]
    }
  ]
}
