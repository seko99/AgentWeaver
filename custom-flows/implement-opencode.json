{
  "kind": "implement-flow",
  "version": 1,
  "phases": [
    {
      "id": "implement",
      "steps": [
        {
          "id": "run_codex_implement",
          "node": "opencode-prompt",
          "prompt": {
            "templateRef": "implement",
            "vars": {
              "design_file": {
                "artifact": {
                  "kind": "design-file",
                  "taskKey": {
                    "ref": "params.taskKey"
                  }
                }
              },
              "design_json_file": {
                "artifact": {
                  "kind": "design-json-file",
                  "taskKey": {
                    "ref": "params.taskKey"
                  }
                }
              },
              "plan_file": {
                "artifact": {
                  "kind": "plan-file",
                  "taskKey": {
                    "ref": "params.taskKey"
                  }
                }
              },
              "plan_json_file": {
                "artifact": {
                  "kind": "plan-json-file",
                  "taskKey": {
                    "ref": "params.taskKey"
                  }
                }
              }
            },
            "extraPrompt": {
              "ref": "params.extraPrompt"
            },
            "format": "task-prompt"
          },
          "params": {
            "labelText": {
              "const": "Running OpenCode implementation mode locally"
            },
            "model": {
              "const": "minimax-coding-plan/MiniMax-M2.7"
            }
          }
        }
      ]
    }
  ]
}
